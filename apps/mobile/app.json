{
  "expo": {
    "name": "Uniqcall Education",
    "slug": "uniqcall-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "uniqcall",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "package": "com.uniqcall.education"
    },
    "ios": {
      "bundleIdentifier": "com.uniqcall.education"
    }
  }
}
